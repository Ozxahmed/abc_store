# ==================================================
# PostgreSQL container initialization
# Used by Docker/Postgres during first-time setup
# ==================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abc_store

# ==================================================
# Local client connection settings
# Used by host-based tools like DBeaver, psql, Python, etc.
# ==================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abc_store
DB_USER=postgres
DB_PASSWORD=postgres